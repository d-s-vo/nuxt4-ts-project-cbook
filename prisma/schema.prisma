// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Описываем уровни сложности для базы данных
enum Difficulty {
  LOW    @map("легко")
  MEDIUM @map("средне")
  HIGH   @map("сложно")
}

// Таблица рецептов
model Recipe {
  id          Int          @id @default(autoincrement())
  title       String
  description String
  cookingTime Int
  servings    Int
  difficulty  Difficulty
  imageUrl    String?      // Опциональное поле (может быть null)
  steps       String[]     // Массив строк (шаги приготовления)
  ingredients Ingredient[] // Связь с таблицей ингредиентов

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

// Таблица ингредиентов
model Ingredient {
  id       Int    @id @default(autoincrement())
  name     String
  quantity Float  // Float, чтобы можно было записать 1.5 литра или 0.5 ложки
  unit     String // Единица измерения (г, кг, шт, ст.л.)
  
  recipeId Int
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
}