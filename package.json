{
  "name": "vue-ts-cbook",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "description": "Modern Vue.js boilerplate with Nuxt 4, TypeScript, Tailwind CSS, and Nuxt UI 4",
  "scripts": {
    "build": "prisma generate && nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
